<!DOCTYPE html>
<html lang="en" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="color-scheme" content="light dark">
  <meta name="supported-color-schemes" content="light dark">
  <title>{{subject_line}}</title>
  <style type="text/css">
    :root { color-scheme: light dark; supported-color-schemes: light dark; }
    body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { -ms-interpolation-mode: bicubic; border: 0; outline: none; text-decoration: none; }
    body { margin: 0; padding: 0; background-color: #f4f4f4; width: 100% !important; }
    a { color: #F3701E; text-decoration: none; }
    a:hover { text-decoration: underline; }
    @media only screen and (max-width: 600px) {
      .email-container { width: 100% !important; }
      .mobile-padding { padding: 24px 20px !important; }
      .logo { width: 140px !important; height: auto !important; }
    }
  </style>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f4;">

  <div style="display:none;font-size:1px;color:#f4f4f4;line-height:1px;max-height:0px;max-width:0px;opacity:0;overflow:hidden;mso-hide:all;">
    {{preheader_text}}
  </div>

  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color:#f4f4f4;">
    <tr>
      <td align="center" style="padding:32px 16px;">
        <table class="email-container" role="presentation" width="600" cellspacing="0" cellpadding="0" border="0" style="background-color:#ffffff;border-radius:8px;overflow:hidden;">

          <tr>
            <td style="background-color:#F3701E;height:6px;font-size:0;line-height:0;">&nbsp;</td>
          </tr>

          <tr>
            <td class="mobile-padding" style="padding:32px 40px 24px 40px;border-bottom:1px solid #E8D8C9;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td align="left">
                    <a href="{{website_url}}" target="_blank" style="font-family:Arial,Helvetica,sans-serif;font-size:20px;font-weight:900;color:#2E3D52;letter-spacing:-0.02em;">
                      ARCHIVE<span style="color:#F3701E;">DAILY</span>
                    </a>
                  </td>
                  <td align="right" valign="middle">
                    <span style="font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#7A8A9A;letter-spacing:0.08em;text-transform:uppercase;">Daily Brief</span><br>
                    <span style="font-family:Arial,Helvetica,sans-serif;font-size:11px;color:#7A8A9A;">{{date_string}}</span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td class="mobile-padding" style="padding:36px 40px;">

              <h1 style="font-family:Arial,Helvetica,sans-serif;font-size:24px;font-weight:700;color:#2E3D52;margin:0 0 16px 0;line-height:1.3;">{{headline}}</h1>
              <p style="font-family:Arial,Helvetica,sans-serif;font-size:15px;color:#1A2535;line-height:1.7;margin:0 0 32px 0;">{{intro_text}}</p>

              {{#each stories}}
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 16px 0;">
                <tr>
                  <td style="padding:10px 16px;background-color:{{theme_dark_color}};border-radius:6px 6px 0 0;">
                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td>
                          <span style="font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#E8D8C9;letter-spacing:0.1em;text-transform:uppercase;">{{category}}</span>
                        </td>
                        <td align="right">
                          <span style="font-family:Arial,Helvetica,sans-serif;font-size:11px;color:{{source_text_color}};">{{source}}</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td style="padding:20px;background-color:#F5EDE3;border-radius:0 0 6px 6px;border-left:3px solid {{theme_dark_color}};">
                    <h2 style="font-family:Arial,Helvetica,sans-serif;font-size:18px;font-weight:700;color:#1A2535;margin:0 0 8px 0;"><a href="{{url}}" style="color:#1A2535;">{{title}} ↗</a></h2>
                    <p style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#4B607F;line-height:1.7;margin:0;">{{description}}</p>
                  </td>
                </tr>
              </table>
              {{/each}}
              <div style="height:16px;font-size:0;line-height:0;">&nbsp;</div>

              {{#if quick_links}}
              <h3 style="font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:700;color:#7A8A9A;letter-spacing:0.05em;text-transform:uppercase;margin:0 0 12px 0;">Quick Links</h3>
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 36px 0; border:1px solid #E8D8C9; border-radius:6px;">
                {{#each quick_links}}
                <tr>
                  <td style="padding:12px 16px;{{#unless @last}}border-bottom:1px solid #E8D8C9;{{/unless}} font-family:Arial,Helvetica,sans-serif;font-size:14px;">
                    <span style="color:#F3701E;margin-right:8px;">●</span> <a href="{{url}}" style="color:#1A2535;text-decoration:none;">{{title}}</a> <span style="color:#7A8A9A;font-size:12px;float:right;">↗</span>
                  </td>
                </tr>
                {{/each}}
              </table>
              {{/if}}

              {{#if tool_of_the_day}}
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 36px 0;">
                <tr>
                  <td style="padding:12px 16px;background-color:#F3701E;border-radius:6px 6px 0 0;">
                    <span style="font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;color:#ffffff;letter-spacing:0.1em;text-transform:uppercase;">Tool of the Day</span>
                  </td>
                </tr>
                <tr>
                  <td style="padding:20px;background-color:#FDE8D9;border-radius:0 0 6px 6px;border-left:3px solid #F3701E;">
                    <h2 style="font-family:Arial,Helvetica,sans-serif;font-size:20px;font-weight:700;color:#1A2535;margin:0 0 12px 0;"><a href="{{tool_of_the_day.url}}" style="color:#1A2535;">{{tool_of_the_day.title}} ↗</a></h2>
                    <p style="font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#1A2535;line-height:1.7;margin:0 0 16px 0;">{{tool_of_the_day.description}}</p>
                    
                    {{#if tool_of_the_day.quote}}
                    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td style="background-color:#ffffff;border-radius:6px;padding:14px 16px;border:1px solid #E8D8C9;">
                          <p style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#4B607F;line-height:1.6;margin:0;font-style:italic;">"{{tool_of_the_day.quote}}"</p>
                        </td>
                      </tr>
                    </table>
                    {{/if}}
                  </td>
                </tr>
              </table>
              {{/if}}

              <hr style="border:none;border-top:1px solid #E8D8C9;margin:0 0 32px 0;">

              {{#if promo}}
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 32px 0;">
                <tr>
                  <td align="center">
                    <img src="{{promo.logo_url}}" width="140" height="auto" alt="{{promo.brand_name}}" style="display:block;border:0;margin-bottom:16px;">
                    <h2 style="font-family:Arial,Helvetica,sans-serif;font-size:20px;font-weight:700;color:#2E3D52;margin:0 0 12px 0;">{{promo.headline}}</h2>
                    <p style="font-family:Arial,Helvetica,sans-serif;font-size:15px;color:#4B607F;line-height:1.6;margin:0 0 20px 0;max-width:450px;">{{promo.description}}</p>
                    <a href="{{promo.cta_url}}" target="_blank" style="display:inline-block;padding:14px 28px;font-family:Arial,Helvetica,sans-serif;font-size:15px;font-weight:700;color:#ffffff;background-color:#F3701E;text-decoration:none;border-radius:6px;">{{promo.cta_text}} &rarr;</a>
                  </td>
                </tr>
              </table>
              {{/if}}

              <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 12px 0;">
                <tr>
                  <td style="padding:0 12px 0 0;vertical-align:middle;">
                    <img src="{{author_image_url}}" width="56" height="56" alt="{{author_name}}" style="display:block;width:56px;height:56px;border-radius:50%;border:1px solid #E8D8C9;object-fit:cover;">
                  </td>
                  <td style="vertical-align:middle;">
                    <p style="font-family:Arial,Helvetica,sans-serif;font-size:15px;color:#1A2535;line-height:1.7;margin:0 0 6px 0;">&mdash; {{author_name}}</p>
                  </td>
                </tr>
              </table>
              {{#if ps_text}}
              <p style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#7A8A9A;line-height:1.6;margin:0;">{{ps_text}}</p>
              {{/if}}

            </td>
          </tr>

          <tr>
            <td style="background-color:#F5EDE3;padding:24px 40px;border-top:1px solid #E8D8C9;">
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#7A8A9A;line-height:1.6;">
                    <strong style="color:#2E3D52;">*|LIST:COMPANY|*</strong><br>
                    *|LIST:ADDRESSLINE|*<br>
                    <a href="*|LIST:URL|*" target="_blank" style="color:#F3701E;text-decoration:none;">Visit our website</a>
                  </td>
                  <td align="right" valign="top" style="font-family:Arial,Helvetica,sans-serif;font-size:11px;color:#7A8A9A;line-height:1.6;">
                    <a href="*|UNSUB|*" style="color:#7A8A9A;text-decoration:underline;">Unsubscribe</a><br>
                    <a href="*|UPDATE_PROFILE|*" style="color:#7A8A9A;text-decoration:underline;">Update preferences</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td style="background-color:#F3701E;height:4px;font-size:0;line-height:0;">&nbsp;</td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
